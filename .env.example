# Firebase is OPTIONAL. Leave these blank to run fully local/offline.
# Fill them in (Firebase console → Project settings → Your apps → Web app)
# to enable optional cloud backup & sync from Settings → Cloud.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Bunny CDN — OPTIONAL image uploads (progress + assessment photos).
# Leave blank to keep photos device-local only. NOTE: the storage key ships in
# the client bundle, so it (and the uploaded files) are publicly reachable —
# use a dedicated zone or an upload proxy if that matters.
VITE_BUNNY_STORAGE_ZONE=
VITE_BUNNY_API_KEY=
VITE_BUNNY_CDN_URL=
VITE_BUNNY_STORAGE_REGION=
