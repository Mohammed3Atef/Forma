rules_version = '2';

// Forma — role-based access control.
// The frontend only HIDES UI; these rules are the real enforcement boundary.
// Role/permission baselines mirror src/services/auth/roles.ts — keep in sync.

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- helpers ---------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }
    function meExists() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function me() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function myRole() {
      return meExists() ? me().role : 'none';
    }
    function isActive() {
      return meExists() && me().accountStatus == 'active';
    }
    function isSuperAdmin() {
      return isActive() && myRole() == 'super_admin';
    }
    function isAdmin() {
      return isActive() && (myRole() == 'admin' || myRole() == 'super_admin');
    }
    function isCoach() {
      return isActive() && myRole() == 'coach';
    }
    function myPermissions() {
      return isActive() ? me().permissions : [];
    }
    // Effective permission = role baseline OR explicit grant.
    function hasPermission(p) {
      return isActive() && (
        isSuperAdmin()
        || (isAdmin() && p in [
              'users.read', 'users.create', 'users.manageRoles', 'users.manageStatus',
              'coaches.assign', 'clients.readAll', 'flags.manage', 'audit.read'])
        || (isCoach() && p in ['users.read'])
        || (p in myPermissions())
      );
    }
    // Coach assigned to this client via an active relationship (deterministic id).
    function isAssignedCoach(clientId) {
      return isCoach()
        && exists(/databases/$(database)/documents/coachClients/$(request.auth.uid + '__' + clientId))
        && get(/databases/$(database)/documents/coachClients/$(request.auth.uid + '__' + clientId)).data.status == 'active';
    }
    // Collections under clientData the client may READ but never WRITE — they are
    // coach-owned. Everything else under clientData (logs, settings, reminders,
    // deletions, …) is the client's own. Daily nutrition substitutions live in
    // nutritionLogs/{date}, which the client owns — NOT in plan/nutrition.
    function isCoachOwnedColl(coll) {
      return coll in ['plan', 'coachNotes', 'coachTargets', 'workoutPlans', 'nutritionPlans', 'planVersions'];
    }

    // ---- users (identity / access control) -------------------------------
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || hasPermission('users.read'));

      // Self sign-up: only with locked defaults on your OWN doc.
      function isSelfProvisionDefaults() {
        return request.auth.uid == uid
          && request.resource.data.role == 'client'
          && request.resource.data.accountStatus in ['pending', 'active']
          && request.resource.data.permissions.size() == 0
          && request.resource.data.createdBy == 'self';
      }
      // Admin-provisioned: super_admin may create any role; admin only client/coach.
      // A coach may create a CLIENT assigned to themselves (coach-driven onboarding).
      allow create: if isSignedIn() && (
        isSelfProvisionDefaults()
        || isSuperAdmin()
        || (hasPermission('users.create') && request.resource.data.role in ['client', 'coach'])
        || (isCoach()
            && request.resource.data.role == 'client'
            && request.resource.data.accountStatus == 'active'
            && request.resource.data.permissions.size() == 0
            && request.resource.data.assignedCoachId == request.auth.uid
            && request.resource.data.createdBy == request.auth.uid)
      );

      allow update: if isSignedIn() && (
        // Self: must not touch any control field.
        (request.auth.uid == uid
          && request.resource.data.role == resource.data.role
          && request.resource.data.permissions == resource.data.permissions
          && request.resource.data.accountStatus == resource.data.accountStatus
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.get('assignedCoachId', '') == resource.data.get('assignedCoachId', ''))
        // Super admin: unrestricted.
        || isSuperAdmin()
        // Admin-level actions apply ONLY to client/coach targets — an admin can
        // never modify an admin or super_admin account.
        || (resource.data.role in ['client', 'coach'] && (
              // Status change (role & permissions unchanged).
              (hasPermission('users.manageStatus')
                && request.resource.data.role == resource.data.role
                && request.resource.data.permissions == resource.data.permissions)
              // Coach assignment change (role/permissions/status unchanged).
              || (hasPermission('coaches.assign')
                && request.resource.data.role == resource.data.role
                && request.resource.data.permissions == resource.data.permissions
                && request.resource.data.accountStatus == resource.data.accountStatus)
              // Role change, limited to client/coach.
              || (hasPermission('users.manageRoles')
                && request.resource.data.role in ['client', 'coach'])
           ))
        // Assigned coach may change ONLY the account status of their OWN client
        // (freeze/pending/trash) — never role, permissions, or assignment.
        || (isAssignedCoach(uid)
            && resource.data.role == 'client'
            && request.resource.data.role == resource.data.role
            && request.resource.data.permissions == resource.data.permissions
            && request.resource.data.get('assignedCoachId', '') == resource.data.get('assignedCoachId', '')
            && request.resource.data.accountStatus in ['active', 'suspended', 'pending', 'disabled'])
      );

      // Prefer status 'disabled' over hard delete; only super_admin may delete.
      allow delete: if isSuperAdmin();
    }

    // ---- coachClients (assignment relationships) -------------------------
    match /coachClients/{relId} {
      allow read: if isSignedIn() && (
        resource.data.coachId == request.auth.uid
        || resource.data.clientId == request.auth.uid
        || hasPermission('users.read'));
      // Admins assign anyone; a coach may link a client to themselves.
      allow create: if hasPermission('coaches.assign')
        || (isCoach() && request.resource.data.coachId == request.auth.uid);
      allow update, delete: if hasPermission('coaches.assign')
        || (isCoach() && resource.data.coachId == request.auth.uid);
    }

    // ---- clientData (fitness data) ---------------------------------------
    // Read: owner, assigned coach, or admin oversight. (Recursive so it also
    // covers the singletons profile/main, settings/app and tombstones.)
    match /clientData/{clientId}/{document=**} {
      allow read: if isSignedIn() && (
        request.auth.uid == clientId
        || isAssignedCoach(clientId)
        || hasPermission('clients.readAll'));
    }
    // Write is scoped per collection so the client can manage their OWN data but
    // never the coach-owned source plans/notes/targets (which are read-only to
    // them). All client data is exactly one collection deep.
    match /clientData/{clientId}/{coll}/{docId} {
      // The client owns their logs, profile, settings, reminders, deletions… —
      // including nutritionLogs/{date} (daily meal swaps / substitutions).
      // The onboarding assessment is carved out below (status-aware lock).
      allow write: if isActive() && request.auth.uid == clientId
        && !isCoachOwnedColl(coll)
        && !(coll == 'profile' && docId == 'assessment');
      // The assigned coach (or an admin with clients.writeAll) authors the
      // coach-owned docs, and may set the client's starting profile.
      allow write: if (isAssignedCoach(clientId) || hasPermission('clients.writeAll'))
        && (isCoachOwnedColl(coll) || coll == 'profile');
    }

    // ---- coach-writable client collections -------------------------------
    // The client can already write these via the generic rule above (neither is
    // coach-owned); these blocks ADD the assigned coach (or admin clients.writeAll).
    // Coach may record body measurements for their client (client still owns theirs).
    match /clientData/{clientId}/measurementLogs/{docId} {
      allow write: if isAssignedCoach(clientId) || hasPermission('clients.writeAll');
    }
    // In-app notifications: the coach creates client-bound alerts (and marks
    // coach-bound ones seen); the client writes coach-bound alerts + marks their
    // own seen via the generic clientData write rule.
    match /clientData/{clientId}/notifications/{docId} {
      allow write: if isAssignedCoach(clientId) || hasPermission('clients.writeAll');
    }

    // ---- onboarding assessment (status-aware) ----------------------------
    // The client may create + edit their assessment until the coach has marked
    // it `reviewed`; the assigned coach (or admin clients.writeAll) writes the
    // review fields (coachNotes / reviewed / reset). Admins are read-only.
    match /clientData/{clientId}/profile/assessment {
      allow read: if isSignedIn() && (
        request.auth.uid == clientId
        || isAssignedCoach(clientId)
        || hasPermission('clients.readAll'));
      allow create: if isActive() && request.auth.uid == clientId;
      allow update: if isActive() && request.auth.uid == clientId
        && resource.data.status != 'reviewed';
      allow update: if isAssignedCoach(clientId) || hasPermission('clients.writeAll');
    }

    // ---- subscription freeze requests ------------------------------------
    // The client creates/cancels their own request via the generic clientData
    // write rule above (subscriptionRequest is not coach-owned); the assigned
    // coach (or admin) writes the decision here.
    match /clientData/{clientId}/subscriptionRequest/{docId} {
      allow read: if isSignedIn() && (
        request.auth.uid == clientId
        || isAssignedCoach(clientId)
        || hasPermission('clients.readAll'));
      allow write: if isAssignedCoach(clientId) || hasPermission('clients.writeAll');
    }

    // ---- planTemplates (coach-owned, legacy) -----------------------------
    match /planTemplates/{id} {
      allow read: if isSignedIn() && (resource.data.coachId == request.auth.uid || hasPermission('users.read'));
      allow create: if isCoach() && request.resource.data.coachId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.coachId == request.auth.uid;
    }

    // ---- coachAssets (coach-owned exercise library + templates) ----------
    // The coach owns everything under their own coachAssets/{coachId} subtree
    // (exercises, workoutTemplates, nutritionTemplates, foods). Admins may read
    // for oversight; assigning to a client writes the client plan, which is
    // separately gated by isAssignedCoach on clientData/{clientId}/plan.
    match /coachAssets/{coachId}/{document=**} {
      allow read: if isSignedIn() && (request.auth.uid == coachId || hasPermission('users.read'));
      allow write: if isActive() && request.auth.uid == coachId;
    }

    // ---- adminAuditLogs (best-effort, create-only, immutable) ------------
    match /adminAuditLogs/{logId} {
      allow read: if hasPermission('audit.read');
      allow create: if isActive()
        && request.resource.data.actorId == request.auth.uid
        && request.resource.data.actorRole == myRole();
      allow update, delete: if false;
    }

    // ---- featureFlags ----------------------------------------------------
    match /featureFlags/{flagId} {
      allow read: if isSignedIn();
      allow write: if hasPermission('flags.manage');
    }

    // Everything else is denied by default.
  }
}
