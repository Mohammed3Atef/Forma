rules_version = '2';

// Forma — role-based access control.
// The frontend only HIDES UI; these rules are the real enforcement boundary.
// Role/permission baselines mirror src/services/auth/roles.ts — keep in sync.

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- helpers ---------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }
    function meExists() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function me() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function myRole() {
      return meExists() ? me().role : 'none';
    }
    function isActive() {
      return meExists() && me().accountStatus == 'active';
    }
    function isSuperAdmin() {
      return isActive() && myRole() == 'super_admin';
    }
    function isAdmin() {
      return isActive() && (myRole() == 'admin' || myRole() == 'super_admin');
    }
    function isCoach() {
      return isActive() && myRole() == 'coach';
    }
    function myPermissions() {
      return isActive() ? me().permissions : [];
    }
    // Effective permission = role baseline OR explicit grant.
    function hasPermission(p) {
      return isActive() && (
        isSuperAdmin()
        || (isAdmin() && p in [
              'users.read', 'users.create', 'users.manageRoles', 'users.manageStatus',
              'coaches.assign', 'clients.readAll', 'flags.manage', 'audit.read'])
        || (isCoach() && p in ['users.read'])
        || (p in myPermissions())
      );
    }
    // Coach assigned to this client via an active relationship (deterministic id).
    function isAssignedCoach(clientId) {
      return isCoach()
        && exists(/databases/$(database)/documents/coachClients/$(request.auth.uid + '__' + clientId))
        && get(/databases/$(database)/documents/coachClients/$(request.auth.uid + '__' + clientId)).data.status == 'active';
    }
    // The signed-in CLIENT's own assigned coach (active relationship) — lets a
    // client read their coach's public record (name / phone / photo) for the
    // "Your Coach" card. Deterministic id: coachId + '__' + me.
    function isMyCoach(coachId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/coachClients/$(coachId + '__' + request.auth.uid))
        && get(/databases/$(database)/documents/coachClients/$(coachId + '__' + request.auth.uid)).data.status == 'active';
    }
    // A coach's Layer-A plan doc (coachPlans/{coachId}); used for the client cap.
    function coachPlan(coachId) {
      return get(/databases/$(database)/documents/coachPlans/$(coachId)).data;
    }
    function coachPlanExists(coachId) {
      return exists(/databases/$(database)/documents/coachPlans/$(coachId));
    }
    // True when the coach is at/over their client cap. Missing plan or counter =
    // not blocked (legacy/best-effort; .get() keeps old docs working).
    function coachAtClientCap(coachId) {
      return coachPlanExists(coachId)
        && coachPlan(coachId).get('activeClientCount', 0) >= coachPlan(coachId).get('maxClients', 999999);
    }
    // A signup invite naming `coachId` that is still claimable BY this user. The
    // code (= doc id) is the capability the visitor presents from the URL.
    function inviteValidFor(coachId, code) {
      return code is string && code.size() > 0
        && exists(/databases/$(database)/documents/signupInvites/$(code))
        && get(/databases/$(database)/documents/signupInvites/$(code)).data.coachId == coachId
        && get(/databases/$(database)/documents/signupInvites/$(code)).data.status == 'pending';
    }
    // The client subscription state the coach chose on the invite (default trial).
    function inviteSubStatus(code) {
      return get(/databases/$(database)/documents/signupInvites/$(code)).data.get('subStatus', 'trial');
    }
    // Collections under clientData the client may READ but never WRITE — they are
    // coach-owned. Everything else under clientData (logs, settings, reminders,
    // deletions, …) is the client's own. Daily nutrition substitutions live in
    // nutritionLogs/{date}, which the client owns — NOT in plan/nutrition.
    function isCoachOwnedColl(coll) {
      return coll in ['plan', 'coachNotes', 'coachTargets', 'workoutPlans', 'nutritionPlans', 'planVersions', 'checkIns'];
    }

    // ---- users (identity / access control) -------------------------------
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || hasPermission('users.read') || isMyCoach(uid));

      // Self sign-up: only with locked defaults on your OWN doc. Widened (Phase 1)
      // to allow a coach self-signup — a coach must be created `active`, with no
      // permissions and createdBy=='self' (open coach registration + trial plan).
      // Self-provision NEVER carries an assignedCoachId (that is invite-driven,
      // handled separately below) — so a client can't attach to a coach here.
      function isSelfProvisionDefaults() {
        return request.auth.uid == uid
          && request.resource.data.role in ['client', 'coach']
          && (request.resource.data.role == 'client'
                ? request.resource.data.accountStatus in ['pending', 'active']
                : request.resource.data.accountStatus == 'active')
          && request.resource.data.permissions.size() == 0
          && request.resource.data.createdBy == 'self'
          && request.resource.data.get('assignedCoachId', '') == '';
      }
      // Invite-driven self-assignment: a brand-new CLIENT may create their OWN
      // identity doc with assignedCoachId==X and createdBy=='self' ONLY when a
      // matching pending invite (named by the code they carry) exists for X.
      // The single relationship write is permitted by the coachClients rule.
      function isInviteSelfProvision() {
        return request.auth.uid == uid
          && request.resource.data.role == 'client'
          && request.resource.data.accountStatus == 'active'
          && request.resource.data.permissions.size() == 0
          && request.resource.data.createdBy == 'self'
          && inviteValidFor(request.resource.data.get('assignedCoachId', ''), request.resource.data.get('inviteCode', ''));
      }
      // Admin-provisioned: super_admin may create any role; admin only client/coach.
      // A coach may create a CLIENT assigned to themselves (coach-driven onboarding).
      allow create: if isSignedIn() && (
        isSelfProvisionDefaults()
        || isInviteSelfProvision()
        || isSuperAdmin()
        || (hasPermission('users.create') && request.resource.data.role in ['client', 'coach'])
        || (isCoach()
            && request.resource.data.role == 'client'
            && request.resource.data.accountStatus == 'active'
            && request.resource.data.permissions.size() == 0
            && request.resource.data.assignedCoachId == request.auth.uid
            && request.resource.data.createdBy == request.auth.uid)
      );

      allow update: if isSignedIn() && (
        // Self: must not touch any control field. Reads use .get() with defaults
        // so a legacy doc missing a control field doesn't raise a rule error —
        // equality still blocks any change to role/permissions/status/etc.
        (request.auth.uid == uid
          && request.resource.data.get('role', '') == resource.data.get('role', '')
          && request.resource.data.get('permissions', []) == resource.data.get('permissions', [])
          && request.resource.data.get('accountStatus', '') == resource.data.get('accountStatus', '')
          && request.resource.data.get('createdBy', '') == resource.data.get('createdBy', '')
          && request.resource.data.get('assignedCoachId', '') == resource.data.get('assignedCoachId', ''))
        // Assigned coach may change ONLY the account status of their OWN client
        // (freeze/trash/reactivate) — never role, permissions, or assignment.
        // Evaluated EARLY (right after self) on purpose: a coach's write must
        // short-circuit here BEFORE the read-heavy admin hasPermission() chain
        // below. Each hasPermission() re-derives isActive/isSuperAdmin/isAdmin/
        // isCoach (many get(users/me) reads); running all three first blows past
        // Firestore's 10 document-access limit per evaluation, which errors the
        // whole rule and denies with "Missing or insufficient permissions" even
        // though every condition here is satisfied. Field reads use .get() with
        // defaults so a legacy doc missing a field doesn't raise a rule error;
        // equality is still enforced, so no privilege escalation is possible.
        || (isAssignedCoach(uid)
            && resource.data.get('role', '') == 'client'
            && request.resource.data.get('role', '') == resource.data.get('role', '')
            && request.resource.data.get('permissions', []) == resource.data.get('permissions', [])
            && request.resource.data.get('assignedCoachId', '') == resource.data.get('assignedCoachId', '')
            && request.resource.data.accountStatus in ['active', 'suspended', 'pending', 'disabled'])
        // Existing-client lifecycle by a coach on a CLIENT doc: CLAIM an unassigned
        // client to self (assignedCoachId '' → self) or RELEASE own client (self → '').
        // role/permissions/accountStatus are frozen, so a coach can never escalate
        // or touch a client owned by ANOTHER coach (assignedCoachId must be '' or self).
        || (isCoach()
            && resource.data.get('role', '') == 'client'
            && request.resource.data.get('role', '') == resource.data.get('role', '')
            && request.resource.data.get('permissions', []) == resource.data.get('permissions', [])
            && request.resource.data.get('accountStatus', '') == resource.data.get('accountStatus', '')
            && (
              (resource.data.get('assignedCoachId', '') == '' && request.resource.data.get('assignedCoachId', '') == request.auth.uid)
              || (resource.data.get('assignedCoachId', '') == request.auth.uid && request.resource.data.get('assignedCoachId', '') == '')
            ))
        // Super admin: unrestricted.
        || isSuperAdmin()
        // Admin-level actions apply ONLY to client/coach targets — an admin can
        // never modify an admin or super_admin account.
        || (resource.data.get('role', '') in ['client', 'coach'] && (
              // Status change (role & permissions unchanged).
              (hasPermission('users.manageStatus')
                && request.resource.data.get('role', '') == resource.data.get('role', '')
                && request.resource.data.get('permissions', []) == resource.data.get('permissions', []))
              // Coach assignment change (role/permissions/status unchanged).
              || (hasPermission('coaches.assign')
                && request.resource.data.get('role', '') == resource.data.get('role', '')
                && request.resource.data.get('permissions', []) == resource.data.get('permissions', [])
                && request.resource.data.accountStatus == resource.data.accountStatus)
              // Role change, limited to client/coach.
              || (hasPermission('users.manageRoles')
                && request.resource.data.get('role', '') in ['client', 'coach'])
           ))
      );

      // Prefer status 'disabled' over hard delete; only super_admin may delete.
      allow delete: if isSuperAdmin();
    }

    // ---- coachClients (assignment relationships) -------------------------
    match /coachClients/{relId} {
      allow read: if isSignedIn() && (
        resource.data.coachId == request.auth.uid
        || resource.data.clientId == request.auth.uid
        || hasPermission('users.read'));
      // maxClients gate (production): REJECT a new relationship once the coach is
      // at/over their cap. The maintained coachPlans.activeClientCount is the
      // server-validated guard (counter drift is reconciled by a script). Legacy
      // coaches without a plan doc are not blocked (.get() defaults).
      // Admins assign anyone; a coach may link a client to themselves; an
      // invited client may self-create the SINGLE relationship to their coach
      // when a matching pending invite exists.
      allow create: if (
        // Invited client self-claim (evaluated FIRST so an invited client never
        // triggers the admin/coach me() reads below — keeps within the doc budget).
        (request.resource.data.clientId == request.auth.uid
            && request.resource.data.status == 'active'
            && relId == request.resource.data.coachId + '__' + request.auth.uid
            && inviteValidFor(request.resource.data.coachId, request.resource.data.get('inviteCode', ''))
            && request.resource.data.get('subscription', {}).get('status', '') == inviteSubStatus(request.resource.data.get('inviteCode', ''))
            && !coachAtClientCap(request.resource.data.coachId))
        || (isCoach() && request.resource.data.coachId == request.auth.uid && !coachAtClientCap(request.auth.uid))
        || (hasPermission('coaches.assign') && !coachAtClientCap(request.resource.data.coachId))
      );
      allow update, delete: if hasPermission('coaches.assign')
        || (isCoach() && resource.data.coachId == request.auth.uid);
    }

    // ---- clientData (fitness data) ---------------------------------------
    // Read: owner, assigned coach, or admin oversight. (Recursive so it also
    // covers the singletons profile/main, settings/app and tombstones.)
    match /clientData/{clientId}/{document=**} {
      allow read: if isSignedIn() && (
        request.auth.uid == clientId
        || isAssignedCoach(clientId)
        || hasPermission('clients.readAll'));
    }
    // Write is scoped per collection so the client can manage their OWN data but
    // never the coach-owned source plans/notes/targets (which are read-only to
    // them). All client data is exactly one collection deep.
    match /clientData/{clientId}/{coll}/{docId} {
      // The client owns their logs, profile, settings, reminders, deletions… —
      // including nutritionLogs/{date} (daily meal swaps / substitutions).
      // The onboarding assessment is carved out below (status-aware lock).
      allow write: if isActive() && request.auth.uid == clientId
        && !isCoachOwnedColl(coll)
        && !(coll == 'profile' && docId == 'assessment');
      // The assigned coach (or an admin with clients.writeAll) authors the
      // coach-owned docs, and may set the client's starting profile.
      allow write: if (isAssignedCoach(clientId) || hasPermission('clients.writeAll'))
        && (isCoachOwnedColl(coll) || coll == 'profile');
    }

    // ---- coach-writable client collections -------------------------------
    // The client can already write these via the generic rule above (neither is
    // coach-owned); these blocks ADD the assigned coach (or admin clients.writeAll).
    // Coach may record body measurements for their client (client still owns theirs).
    match /clientData/{clientId}/measurementLogs/{docId} {
      allow write: if isAssignedCoach(clientId) || hasPermission('clients.writeAll');
    }
    // In-app notifications: the coach creates client-bound alerts (and marks
    // coach-bound ones seen); the client writes coach-bound alerts + marks their
    // own seen via the generic clientData write rule.
    match /clientData/{clientId}/notifications/{docId} {
      allow write: if isAssignedCoach(clientId) || hasPermission('clients.writeAll');
    }
    // Weekly check-ins: the coach creates the request + writes review feedback
    // (granted by the coach branch since checkIns is in isCoachOwnedColl); the
    // client may submit their OWN check-in once, only while it's still 'requested'.
    match /clientData/{clientId}/checkIns/{docId} {
      allow update: if isActive() && request.auth.uid == clientId && resource.data.status == 'requested';
    }
    // Messages: the 1:1 coach⇄client thread — both the client and the assigned
    // coach (or admin clients.writeAll) read + write; either can mark messages seen.
    match /clientData/{clientId}/messages/{docId} {
      allow read, write: if isSignedIn()
        && (request.auth.uid == clientId || isAssignedCoach(clientId) || hasPermission('clients.writeAll'));
    }

    // ---- onboarding assessment (status-aware) ----------------------------
    // The client may create + edit their assessment until the coach has marked
    // it `reviewed`; the assigned coach (or admin clients.writeAll) writes the
    // review fields (coachNotes / reviewed / reset). Admins are read-only.
    match /clientData/{clientId}/profile/assessment {
      allow read: if isSignedIn() && (
        request.auth.uid == clientId
        || isAssignedCoach(clientId)
        || hasPermission('clients.readAll'));
      allow create: if isActive() && request.auth.uid == clientId;
      // Living assessment: the client may always edit their own answers (editing
      // a reviewed doc flips it to 'updated_after_review'); the coach reviews.
      allow update: if isActive() && request.auth.uid == clientId;
      allow update: if isAssignedCoach(clientId) || hasPermission('clients.writeAll');
    }

    // ---- subscription freeze requests ------------------------------------
    // The client creates/cancels their own request via the generic clientData
    // write rule above (subscriptionRequest is not coach-owned); the assigned
    // coach (or admin) writes the decision here.
    match /clientData/{clientId}/subscriptionRequest/{docId} {
      allow read: if isSignedIn() && (
        request.auth.uid == clientId
        || isAssignedCoach(clientId)
        || hasPermission('clients.readAll'));
      allow write: if isAssignedCoach(clientId) || hasPermission('clients.writeAll');
    }

    // ---- coachPlans (Layer A — coach's own subscription to Forma) --------
    // read: the owning coach or anyone with users.read (admin oversight).
    // create: self ONLY with locked trial defaults (plan/status/maxClients fixed
    //   and id == own uid), OR users.manageStatus / super_admin.
    // update/delete: super_admin / users.manage* ONLY — EXCEPT the owning coach
    //   may patch ONLY trialNotified + activeClientCount (never plan/status/
    //   maxClients/startedAt/endsAt). Field reads use .get() so legacy docs work.
    match /coachPlans/{coachId} {
      allow read: if isSignedIn() && (request.auth.uid == coachId || hasPermission('users.read'));

      allow create: if isSignedIn() && (
        (request.auth.uid == coachId
          && request.resource.data.plan == 'trial'
          && request.resource.data.status == 'active'
          && request.resource.data.maxClients == 10)
        || hasPermission('users.manageStatus')
      );

      // Privileged full mutation.
      allow update: if hasPermission('users.manageStatus');
      // Owner coach: only the two self-mutable fields may change.
      allow update: if isSignedIn() && request.auth.uid == coachId
        && request.resource.data.get('plan', '') == resource.data.get('plan', '')
        && request.resource.data.get('status', '') == resource.data.get('status', '')
        && request.resource.data.get('maxClients', 0) == resource.data.get('maxClients', 0)
        && request.resource.data.get('startedAt', 0) == resource.data.get('startedAt', 0)
        && request.resource.data.get('endsAt', 0) == resource.data.get('endsAt', 0)
        && request.resource.data.get('createdAt', 0) == resource.data.get('createdAt', 0);

      allow delete: if hasPermission('users.manageStatus');

      // Coach → super-admin plan-change request (singleton 'current').
      // Coach submits 'pending' / withdraws 'cancelled'; super-admin resolves
      // 'accepted'/'rejected'. Read: the owning coach or admin oversight.
      match /planChangeRequest/{docId} {
        allow read: if isSignedIn() && (request.auth.uid == coachId || hasPermission('users.read'));
        allow create, update: if isSignedIn() && request.auth.uid == coachId
          && request.resource.data.status in ['pending', 'cancelled'];
        allow update: if hasPermission('users.manageStatus')
          && request.resource.data.status in ['accepted', 'rejected'];
        allow delete: if hasPermission('users.manageStatus');
      }
    }

    // Collection-group read for the admin "pending plan requests" query
    // (collectionGroup('planChangeRequest') where status == 'pending').
    match /{path=**}/planChangeRequest/{docId} {
      allow read: if hasPermission('users.read');
    }

    // ---- transferRequests (coach→admin/current-coach client takeover) ----
    // A prospective coach requests a client owned by ANOTHER coach. Doc id is
    // `${toCoachId}__${clientId}`. The requester creates it (pending) and may
    // cancel; the CURRENT coach (fromCoachId) or an admin (coaches.assign)
    // resolves it (accepted/rejected). The actual reassignment + any data
    // clearing still go through the users/coachClients/clientData rules — this
    // doc is only the request record.
    match /transferRequests/{reqId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.toCoachId
        || request.auth.uid == resource.data.fromCoachId
        || hasPermission('users.read'));
      allow create: if isCoach()
        && request.resource.data.toCoachId == request.auth.uid
        && request.resource.data.fromCoachId != request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if (request.auth.uid == resource.data.toCoachId && request.resource.data.status == 'cancelled')
        || (request.auth.uid == resource.data.fromCoachId && request.resource.data.status in ['accepted', 'rejected'])
        || (hasPermission('coaches.assign') && request.resource.data.status in ['accepted', 'rejected']);
      allow delete: if hasPermission('coaches.assign');
    }

    // ---- signupInvites (Phase 1 client invitations) ----------------------
    // The CODE (= doc id) is the capability: any signed-in user may READ a
    // single invite (minimal payload — coach display name is resolved separately
    // and only when pending). create/revoke: the owning coach or coaches.assign.
    // claim (update→claimed): the claiming CLIENT only, while pending and naming
    // themselves; admins/coaches use the create/update branch.
    match /signupInvites/{code} {
      // The CODE is the capability and the claim flow is pre-auth (the visitor
      // reads the invite to see the coach name BEFORE creating their account),
      // so a single-doc read is public. Payload is intentionally minimal (coach
      // display name only — no client PII). LIST is NOT granted (rules only ever
      // resolve a known code), so invites can't be enumerated.
      allow get: if true;
      allow list: if isSignedIn() && (hasPermission('coaches.assign') || isCoach());
      allow create: if hasPermission('coaches.assign')
        || (isCoach() && request.resource.data.coachId == request.auth.uid);
      // Coach/admin update (revoke, edit) — never reassign the invite's coach.
      allow update: if (hasPermission('coaches.assign') || (isCoach() && resource.data.coachId == request.auth.uid))
        && request.resource.data.coachId == resource.data.coachId;
      // Client single-use claim: pending → claimed, by the claimer only. Coach
      // is fixed; only status/claimedByUid/claimedAt change.
      allow update: if isSignedIn()
        && resource.data.status == 'pending'
        && request.resource.data.status == 'claimed'
        && request.resource.data.claimedByUid == request.auth.uid
        && request.resource.data.coachId == resource.data.coachId;
      allow delete: if hasPermission('coaches.assign')
        || (isCoach() && resource.data.coachId == request.auth.uid);
    }

    // ---- planTemplates (coach-owned, legacy) -----------------------------
    match /planTemplates/{id} {
      allow read: if isSignedIn() && (resource.data.coachId == request.auth.uid || hasPermission('users.read'));
      allow create: if isCoach() && request.resource.data.coachId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.coachId == request.auth.uid;
    }

    // ---- coachAssets (coach-owned exercise library + templates) ----------
    // The coach owns everything under their own coachAssets/{coachId} subtree
    // (exercises, workoutTemplates, nutritionTemplates, foods). Admins may read
    // for oversight; assigning to a client writes the client plan, which is
    // separately gated by isAssignedCoach on clientData/{clientId}/plan.
    match /coachAssets/{coachId}/{document=**} {
      allow read: if isSignedIn() && (request.auth.uid == coachId || hasPermission('users.read'));
      allow write: if isActive() && request.auth.uid == coachId;
    }

    // ---- adminAuditLogs (best-effort, create-only, immutable) ------------
    match /adminAuditLogs/{logId} {
      allow read: if hasPermission('audit.read');
      allow create: if isActive()
        && request.resource.data.actorId == request.auth.uid
        && request.resource.data.actorRole == myRole();
      allow update, delete: if false;
    }

    // ---- featureFlags ----------------------------------------------------
    match /featureFlags/{flagId} {
      allow read: if isSignedIn();
      allow write: if hasPermission('flags.manage');
    }

    // Everything else is denied by default.
  }
}
